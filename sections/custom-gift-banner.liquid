{{ 'custom-gift-guide.css' | asset_url | stylesheet_tag }}

<div class="custom-gift-banner-wrapper" id="CustomBanner-{{ section.id }}" style="
  {% if section.settings.bg_image != blank %}
    background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
  {% else %}
    background-color: {{ section.settings.fallback_bg_color }};
  {% endif %}
">
  <div class="custom-gift-banner-container page-width">
    <div class="custom-gift-banner-content">
      {% if section.settings.heading != blank %}
        <h1 class="custom-gift-banner-title">{{ section.settings.heading | escape }}</h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="custom-gift-banner-subtext">{{ section.settings.description | escape }}</p>
      {% endif %}

      {% if section.settings.btn_label != blank %}
        <a href="{{ section.settings.btn_link | default: '#' }}" class="custom-gift-banner-btn">
          <span>{{ section.settings.btn_label | escape }}</span>
          <span class="custom-gift-banner-btn-arrow" aria-hidden="true">&rarr;</span>
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Gift Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Illustration Image (Exported from Figma)"
    },
    {
      "type": "color",
      "id": "fallback_bg_color",
      "label": "Fallback Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Custom Gift Banner"
    }
  ]
}
{% endschema %}

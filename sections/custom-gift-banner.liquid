{{ 'custom-gift-guide.css' | asset_url | stylesheet_tag }}

<div class="cgb-section" id="CustomBanner-{{ section.id }}">

  <!-- ① Top Bar: Hamburger (mobile) | Logo | Tagline | CHOOSE GIFT (desktop) -->
  <div class="cgb-topbar">

    {%- comment -%} Mobile-only hamburger button {%- endcomment -%}
    <button type="button"
            class="cgb-hamburger"
            id="CgbHamburger-{{ section.id }}"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="CgbMobileNav-{{ section.id }}">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="cgb-topbar-logo">{{ section.settings.logo_text | escape }}</div>
    <div class="cgb-topbar-tagline">{{ section.settings.tagline | escape }}</div>

    {%- comment -%} Desktop: CHOOSE GIFT button always visible {%- endcomment -%}
    <div class="cgb-topbar-actions">
      <a href="{{ section.settings.choose_link | default: '#' }}" class="cgb-topbar-btn">
        <span>{{ section.settings.choose_label | escape }}</span>
        <span class="cgb-topbar-btn-arrow" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>

  <!-- Mobile dropdown nav: slides open when hamburger is tapped -->
  <div class="cgb-mobile-nav"
       id="CgbMobileNav-{{ section.id }}"
       aria-hidden="true">
    <a href="{{ section.settings.choose_link | default: '#' }}" class="cgb-topbar-btn cgb-mobile-nav-cta">
      <span>{{ section.settings.choose_label | escape }}</span>
      <span class="cgb-topbar-btn-arrow" aria-hidden="true">&rarr;</span>
    </a>
  </div>

  <!-- ② Hero: stacked on mobile / full overlay on desktop -->
  <div class="cgb-main"{% if section.settings.bg_image != blank %} style="--cgb-bg: url('{{ section.settings.bg_image | image_url: width: 1600 }}');"{% endif %}>

    <!-- Title + description (above image on mobile, bottom-left overlay on desktop) -->
    <div class="cgb-hero-content">
      {% if section.settings.heading != blank %}
        <h1 class="cgb-title">{{ section.settings.heading | escape }}</h1>
      {% endif %}
      {% if section.settings.description != blank %}
        <p class="cgb-desc">{{ section.settings.description | escape }}</p>
      {% endif %}
      <!-- Desktop-only button, positioned at bottom-left with content -->
      {% if section.settings.btn_label != blank %}
        <a href="{{ section.settings.btn_link | default: '#' }}" class="cgb-btn cgb-btn--desktop">
          <span>{{ section.settings.btn_label | escape }}</span>
          <span class="cgb-btn-arrow" aria-hidden="true">&rarr;</span>
        </a>
      {% endif %}
    </div>

    <!-- Illustration: <img> on mobile (hidden on desktop, bg-image used instead) -->
    {% if section.settings.bg_image != blank %}
      <div class="cgb-illustration">
        <img
          src="{{ section.settings.bg_image | image_url: width: 1400 }}"
          alt=""
          width="1400"
          height="400"
          loading="eager"
          class="cgb-illustration-img">

        <!-- Mobile-only button: centered overlay on the illustration -->
        {% if section.settings.btn_label != blank %}
          <div class="cgb-illustration-btn-wrap">
            <a href="{{ section.settings.btn_link | default: '#' }}" class="cgb-btn cgb-btn--mobile">
              <span>{{ section.settings.btn_label | escape }}</span>
              <span class="cgb-btn-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </div>
        {% endif %}
      </div>
    {% endif %}

  </div>




  <!-- ③ Bottom scrolling ticker / announcement -->
  {% if section.settings.ticker_text != blank %}
    <div class="cgb-ticker" aria-label="{{ section.settings.ticker_text | escape }}">
      <div class="cgb-ticker-track" aria-hidden="true">
        {%- for i in (1..8) -%}
          <span class="cgb-ticker-item">{{ section.settings.ticker_text | escape }}</span>
        {%- endfor -%}
      </div>
    </div>
  {% endif %}

</div>

<script>
  (function () {
    var btn = document.getElementById('CgbHamburger-{{ section.id }}');
    var nav = document.getElementById('CgbMobileNav-{{ section.id }}');
    if (!btn || !nav) return;
    btn.addEventListener('click', function () {
      var open = nav.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      btn.classList.toggle('is-active', open);
      nav.setAttribute('aria-hidden', open ? 'false' : 'true');
    });
  })();
</script>

{% schema %}
{
  "name": "Custom Gift Banner",
  "settings": [
    {
      "type": "header",
      "content": "Top Bar"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo / Brand Name",
      "default": "TISSO VISON"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Center Tagline",
      "default": "Find the ideal gift for your loved ones."
    },
    {
      "type": "text",
      "id": "choose_label",
      "label": "CTA Button Label",
      "default": "CHOOSE GIFT"
    },
    {
      "type": "url",
      "id": "choose_link",
      "label": "CTA Button Link"
    },
    {
      "type": "header",
      "content": "Hero Area"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Illustration Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "The Gift Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Shop Button Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Shop Button Link"
    },
    {
      "type": "header",
      "content": "Announcement Ticker"
    },
    {
      "type": "text",
      "id": "ticker_text",
      "label": "Ticker Text",
      "default": "SUSTAINABLE, ETHICALLY MADE CLOTHES IN SIZES XXS TO 6XL!"
    }
  ],
  "presets": [
    {
      "name": "Custom Gift Banner"
    }
  ]
}
{% endschema %}
